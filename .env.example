# ── Groq (gratis) ─────────────────────────────────────────────────────
# Crear cuenta y key en: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Meta WhatsApp Cloud API (gratis) ─────────────────────────────────
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890123
WEBHOOK_VERIFY_TOKEN=cienrayas_secreto

# ── Servidor ──────────────────────────────────────────────────────────
# Para prueba local: URL pública de ngrok (cambia cada vez que reinicias ngrok gratis)
# Ejemplo: https://abc123.ngrok-free.app
# Para Render: dejar vacío — se detecta automáticamente desde RENDER_EXTERNAL_URL
BASE_URL=https://tu-url.ngrok-free.app

MEDIA_DIR=media
